# Copia este archivo como .env y rellena tus valores reales.
# El .env real NUNCA se sube a git (está en .gitignore).

# Obligatoria — API key de Groq (console.groq.com)
GROQ_API_KEY=

# Recomendable en cualquier despliegue fuera de tu ordenador (Railway, Hostinger,
# etc.) — sin esto, el perfil de marca, la voz aprendida, las reseñas de la
# landing y los leads de "prueba gratis" se guardan en archivos locales del
# servidor, que la mayoría de hostings borran en cada redeploy/reinicio. Con
# esto definido, esos datos viven en una base Redis gratuita (upstash.com,
# plan Free) que sobrevive a los redeploys sin importar dónde esté desplegado.
# Sin esto, la app sigue funcionando igual en local (cae en archivos, como antes).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Opcional — token de Pollinations.AI (auth.pollinations.ai, gratis). La opción
# "Generar imagen con IA" funciona SIN esto (uso anónimo, gratis, con una pequeña
# marca de agua). Solo hace falta si quieres quitar la marca de agua o subir el
# límite de 1 imagen/15s — y el registro sigue siendo gratuito.
POLLINATIONS_TOKEN=

# Opcionales — Meta Graph API, para publicar de verdad en Instagram con UNA
# sola cuenta compartida (modo cliente único). Sin esto, la app funciona en
# modo demo (genera captions pero no publica).
META_ACCESS_TOKEN=
META_INSTAGRAM_ACCOUNT_ID=

# Opcionales — SOLO si DATABASE_URL está activa (multi-tenant): permiten que
# cada usuario conecte SU PROPIA cuenta de Instagram desde Configuración, en
# vez de depender del META_ACCESS_TOKEN único de arriba. Salen del panel de
# Meta for Developers → tu app → Instagram → "Configuración de la API con
# inicio de sesión de Instagram" → ID/Secreto de la aplicación de Instagram.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Opcional — activa cuentas de usuario reales (registro/login con email y
# contraseña, un perfil/historial/programados propio por usuario) en vez del
# APP_PASSWORD único de abajo. Connection string de Postgres (recomendado:
# neon.tech, plan Free) — copia el connection string de tu proyecto Neon aquí.
# IMPORTANTE: definir esto cambia el comportamiento de todo el despliegue —
# deja de aceptar peticiones sin login (salvo modo demo, ver DEMO_DAILY_LIMIT
# más abajo). No lo definas en un despliegue de cliente único ya en marcha
# que hoy funciona con APP_PASSWORD sin querer convertirlo en multi-tenant.
# Tras definirla, ejecuta "npm run migrate" una vez para crear las tablas.
DATABASE_URL=

# Obligatoria SOLO si defines DATABASE_URL — secreto para firmar los JWT de
# sesión de las cuentas de usuario. Usa una cadena larga y aleatoria (ej.
# `openssl rand -hex 32`); si la cambias, todas las sesiones activas se invalidan.
JWT_SECRET=

# Obligatoria SOLO si defines META_ACCESS_TOKEN — URL pública de tu despliegue
# (ej. https://tuapp.up.railway.app). Meta exige descargar la imagen desde una
# URL pública para publicarla; no funciona con localhost. Sin esto, publicar de
# verdad falla aunque tengas META_ACCESS_TOKEN configurado.
PUBLIC_URL=

# Opcional — puerto del servidor (por defecto 3001)
PORT=3001

# Opcional pero MUY recomendable si despliegas esto fuera de tu ordenador
# (Railway, etc.). Si la defines, toda la app pide esta contraseña antes de
# dejar pasar nada (usuario: cualquiera, contraseña: este valor).
# Si la dejas vacía/sin definir, la app queda abierta a cualquiera con la URL.
# NO la definas en el despliegue pensado como demo pública/genérica (matriz.html
# necesita ser accesible sin login) — sí en un despliegue dedicado a un cliente real.
APP_PASSWORD=

# Opcional — protege solo GET /api/trial-requests (los leads que piden la
# prueba gratis desde matriz.html: nombre, email...). Sin esto, esa ruta queda
# abierta a quien conozca la URL. Para consultarla: /api/trial-requests?key=TU_ADMIN_KEY
ADMIN_KEY=

# Opcional — SOLO para el despliegue de demo pública abierta (sin login). Si
# defines un número (ej. 3), cada IP solo puede generar ese número de
# captions/imágenes al día; al agotarlo ve un aviso con enlace a matriz.html
# para pedir la prueba completa. NO la definas en un despliegue de cliente real
# (Objetiva Broker, etc.) — ahí el uso debe ser ilimitado.
DEMO_DAILY_LIMIT=
